# ========================================
# Market Mega Bot - Environment Variables
# ========================================
# Bu fayldan nusxa olib ".env" deb saqlang va qiymatlarni to'ldiring.
# cp .env.example .env

# --- Telegram Bot ---
BOT_TOKEN=123456:YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_USERNAME=your_bot_username

# --- Public WebApp URL ---
# Mini App HTTPS orqali ishlashi shart. Lokal test uchun ngrok ishlating.
# Masalan: https://abc123.ngrok.io
WEBAPP_URL=https://your-domain.com

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketmega

# --- Admin Login ---
ADMIN_USERNAME=nodirbek
ADMIN_PASSWORD=zxcv1234

# Admin Telegram ID — yangi buyurtma kelganda xabar olish uchun (ixtiyoriy)
# O'z ID'ingizni bilish uchun @userinfobot'ga yozing
ADMIN_TELEGRAM_ID=

# --- Security ---
# `openssl rand -hex 32` buyrug'i bilan yarating yoki tasodifiy uzun satr
SECRET_KEY=change-me-to-a-long-random-secret-string

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
