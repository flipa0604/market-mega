# ============================================================
# Market Mega Bot - Environment Variables (.env.example)
# ============================================================
# Bu faylni nusxalab `.env` qiling va qiymatlarni to'ldiring.
# `.env` git'ga TUSHMAYDI (.gitignore tomonidan istisnoga olingan).
#
# Linux/Mac:    cp .env.example .env
# Windows:      Copy-Item .env.example .env
# ============================================================


# --- Telegram Bot ----------------------------------------
# BotFather'dan oling: @BotFather → /newbot
BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=your_bot_username


# --- Public WebApp URL ----------------------------------
# Mini App HTTPS bo'lishi shart (Telegram talabi).
# Production: o'z domeningiz, masalan https://shop.example.uz
# Development: ngrok yoki cloudflared tunnel URL'i
WEBAPP_URL=https://shop.example.uz


# --- Database (PostgreSQL) ------------------------------
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Server uchun parolda maxsus belgilarni URL-encode qiling (@ → %40 va h.k.)
DATABASE_URL=postgresql+asyncpg://marketmega:STRONG_PASSWORD@localhost:5432/marketmega


# --- Admin Login (web panel) -----------------------------
# http://your-domain/admin uchun
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-THIS-STRONG-PASSWORD


# --- Admin Telegram (notifications uchun) ----------------
# Yangi buyurtma kelganda va yangi chat xabarida xabar yuboriladi.
#
# Variant A: aniq Telegram ID (raqam):
#   @userinfobot'ga yozing, u sizga ID beradi.
ADMIN_TELEGRAM_ID=

# Variant B: @username — bot bu user botga /start yuborganidan keyin
# uning chat_id'sini DB'dan topadi.
ADMIN_TG_USERNAME=your_admin_username


# --- Security --------------------------------------------
# Session cookie'ni imzolash uchun.
# Yarating: openssl rand -hex 32
SECRET_KEY=CHANGE-ME-TO-RANDOM-STRING-AT-LEAST-32-CHARS


# --- Server ----------------------------------------------
# Production: HOST=127.0.0.1 (faqat nginx orqali kirish)
# Development: HOST=0.0.0.0 (lokal tarmoqda ko'rinadi)
HOST=127.0.0.1
PORT=8000

# Production'da har doim DEBUG=false bo'lsin!
DEBUG=false
