# Default — Git o'zi aniqlasin
* text=auto

# Shell skriptlari va Linux config'lar — har doim LF (Windows'dan ham bo'lsa)
*.sh             text eol=lf
*.service        text eol=lf
*.conf           text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf

# Python ham LF (PEP-8)
*.py             text eol=lf

# HTML/CSS/JS — LF
*.html           text eol=lf
*.css            text eol=lf
*.js             text eol=lf
*.json           text eol=lf

# Markdown
*.md             text eol=lf

# Hech qachon o'zgartirilmasin (binar)
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.webp           binary
*.ico            binary
*.pdf            binary
